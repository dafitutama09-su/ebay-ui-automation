<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="eBay UI Automation Suite"
       parallel="false"
       verbose="1">

    <listeners>
        <listener class-name="core.TestListener"/>
    </listeners>

    <test name="eBay Tests - Chrome">

        <parameter name="browser" value="chrome"/>

        <classes>
            <class name="Ebay.HomeTest"/>
            <class name="Ebay.SearchResultTest"/>
        </classes>

    </test>

</suite>


